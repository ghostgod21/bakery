pipeline {
    agent any

    environment {
        APP_NAME     = 'bakery'
        REMOTE_USER  = 'ubuntu'
        REMOTE_HOST  = '<SERVER_IP>'          // <-- set your Ubuntu server's IP
        REMOTE_PATH  = '/opt/tomcat/webapps'
        SSH_CRED_ID  = 'maven-server-ip'       // <-- Jenkins SSH credentials ID
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Maven Build and Deploy') {
            steps {
                sh 'mvn clean package'

                sshagent(credentials: ["${SSH_CRED_ID}"]) {
                    sh '''
                        scp -o StrictHostKeyChecking=no target/bakers-ecommerce.war ${REMOTE_USER}@${REMOTE_HOST}:/tmp/${APP_NAME}.war
                        ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${REMOTE_HOST} "
                            sudo cp /tmp/${APP_NAME}.war ${REMOTE_PATH}/${APP_NAME}.war &&
                            sudo systemctl restart tomcat
                        "
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "✅ ${APP_NAME} deployed to ${REMOTE_HOST} successfully."
        }
        failure {
            echo "❌ Build or deployment failed."
        }
    }
}
