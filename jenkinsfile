pipeline {
    agent any

    environment {
        APP_NAME     = 'bakery'
        GIT_REPO     = 'https://github.com/ghostgod21/bakery.git'
        GIT_BRANCH   = 'main'
        REMOTE_USER  = 'ubuntu'
        REMOTE_HOST  = '<SERVER_IP>'            // <-- IP of your Maven+Tomcat server
        REMOTE_PATH  = '/opt/tomcat/webapps'
        SSH_CRED_ID  = 'maven-server-ip'        // <-- Jenkins SSH credentials ID
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build and Deploy on Remote Server') {
            steps {
                sshagent(credentials: ["${SSH_CRED_ID}"]) {
                    sh '''
                        ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${REMOTE_HOST} "
                            set -e
                            if [ -d ${APP_NAME} ]; then
                                cd ${APP_NAME} && git pull
                            else
                                git clone -b ${GIT_BRANCH} ${GIT_REPO} ${APP_NAME}
                                cd ${APP_NAME}
                            fi
                            mvn clean package
                            sudo cp target/bakers-ecommerce.war ${REMOTE_PATH}/${APP_NAME}.war
                            sudo systemctl restart tomcat
                        "
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "✅ ${APP_NAME} built and deployed on ${REMOTE_HOST} successfully."
        }
        failure {
            echo "❌ Build or deployment failed."
        }
    }
}
